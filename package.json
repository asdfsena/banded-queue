{
  "name": "@asdfsena/banded-queue",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest",
    "build": "bun build --target=node --outdir=dist src/index.ts --external bullmq --external ioredis",
    "build:types": "tsc --project tsconfig.build.json",
    "release": "bun run build && bun run build:types && npx changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "bullmq": "^5.77.1",
    "ioredis": "^5.10.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asdfsena/banded-queue.git"
  },
  "bugs": {
    "url": "https://github.com/asdfsena/banded-queue/issues"
  },
  "homepage": "https://github.com/asdfsena/banded-queue#readme"
}
